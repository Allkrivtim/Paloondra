# ---------------------------------------------------------------------------
# docker-compose configuration.
#
# This is separate from backend/.env (the app's own runtime config, still
# required - see backend/.env.example) and frontend/.env (only used for
# `npm run dev` outside Docker). Copy this file to `.env` in the repo root;
# docker-compose reads it automatically for the variables referenced below.
# ---------------------------------------------------------------------------

# The URL this panel will actually be opened at in a browser, e.g.
# http://203.0.113.10 or http://paloondra.example.com. This gets baked into
# the frontend's JavaScript at build time (Vite inlines it), so changing it
# later requires `docker compose build frontend` again - it can't be
# changed at container start like a normal runtime env var.
VITE_API_BASE_URL=http://localhost
