#!/bin/sh
# Example backup script - not wired to any panel button (there isn't one),
# but reachable from inside the backend container at /scripts/backup.sh
# once you copy this to backup.sh, for a host cron job or manual use:
#   docker compose exec backend sh /scripts/backup.sh
set -e

SERVER_DIR="/opt/minecraft/server"
BACKUP_DIR="/opt/minecraft/backups"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"

mkdir -p "$BACKUP_DIR"
tar -czf "$BACKUP_DIR/world-$TIMESTAMP.tar.gz" -C "$SERVER_DIR" world
echo "Backed up to $BACKUP_DIR/world-$TIMESTAMP.tar.gz"
