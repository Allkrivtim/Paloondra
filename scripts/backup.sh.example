#!/bin/sh
# Example backup script - not wired to any Dashboard button, but runnable
# the same way as start/stop/restart once you copy this to backup.sh in
# SCRIPTS_DIR on your server: POST /api/server/backup, or just run it by
# hand over SSH.
set -e

SERVER_DIR="/opt/minecraft/server"
BACKUP_DIR="/opt/minecraft/backups"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"

mkdir -p "$BACKUP_DIR"
tar -czf "$BACKUP_DIR/world-$TIMESTAMP.tar.gz" -C "$SERVER_DIR" world
echo "Backed up to $BACKUP_DIR/world-$TIMESTAMP.tar.gz"
