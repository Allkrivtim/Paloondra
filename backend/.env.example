# ---------------------------------------------------------------------------
# Paloondra - backend configuration
#
# This is the ONLY place connection data lives. There is no "add server" UI -
# whatever you configure here is the single server the panel controls.
# Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# HTTP/WebSocket port the backend listens on
PORT=4000

# Comma separated list of origins allowed to call the API/WS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# How long issued tokens stay valid
JWT_EXPIRES_IN=12h

# Users allowed to log in, as comma separated username:bcrypt_hash pairs.
# There is no registration UI - add/remove users by editing this line by hand.
# Generate a hash for a new user with:
#   npm run hash -- "the-password"
# then paste "username:<hash>" into this list.
USERS=admin:$2b$10$replace/with/a/real/bcrypt/hash/generated/by/npm-run-hash

# ---------------------------------------------------------------------------
# RCON
# ---------------------------------------------------------------------------
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=changeme

# ---------------------------------------------------------------------------
# SSH / SFTP - used for the terminal tab, the file manager, host metrics
# (cpu/ram/disk), and the start/stop/restart/backup scripts below. Provide
# either SSH_PASSWORD or SSH_KEY_PATH; if both are set, the private key
# takes precedence.
# ---------------------------------------------------------------------------
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USER=mcadmin
SSH_PASSWORD=
SSH_KEY_PATH=
SSH_KEY_PASSPHRASE=

# ---------------------------------------------------------------------------
# Shell scripts - the panel never touches the Minecraft process directly,
# only these scripts, run over the SSH connection above (not on the machine
# running this backend). SCRIPTS_DIR is an absolute path ON THE TARGET
# SERVER; each script below is just a filename inside it, run as:
#   cd <SCRIPTS_DIR> && ./<filename>
# so scripts that rely on relative paths inside them keep working. All four
# must be executable on the server: chmod +x <SCRIPTS_DIR>/*.sh
# ---------------------------------------------------------------------------
SCRIPTS_DIR=/home/minecraft/scripts
START_SCRIPT=start.sh
STOP_SCRIPT=stop.sh
RESTART_SCRIPT=restart.sh
BACKUP_SCRIPT=backup.sh

# ---------------------------------------------------------------------------
# File manager (SFTP)
# ---------------------------------------------------------------------------

# Directory the File Manager tab opens by default. Must be an absolute path
# that exists on the target host. If unset, or if the path doesn't exist /
# isn't a directory, the panel falls back to SSH_USER's home directory.
SFTP_DEFAULT_PATH=/home/mcadmin/server

# If SSH_USER doesn't own the Minecraft server's files (e.g. they're owned
# by a dedicated "minecraft" service user), set this to true to route every
# file operation through `sudo` over SSH instead of the raw SFTP subsystem.
# Requires a NOPASSWD sudoers entry for SSH_USER - see README for the exact
# /etc/sudoers.d/ file to create before enabling this.
SFTP_USE_SUDO=false

# Path to the sudo binary on the target host, only used when
# SFTP_USE_SUDO=true. Must match the Cmnd_Alias path in your sudoers entry.
SUDO_PATH=/usr/bin/sudo

# ---------------------------------------------------------------------------
# Metrics
# ---------------------------------------------------------------------------
# How often (ms) to poll RCON player list + host cpu/ram/disk
METRICS_INTERVAL_MS=5000
# How many samples to keep in the in-memory ring buffer for the charts
METRICS_HISTORY_SIZE=120

# Max text file size (bytes) the built-in SFTP editor will open
EDITOR_MAX_FILE_SIZE=2097152

# ---------------------------------------------------------------------------
# Plugins - all optional, like SFTP_DEFAULT_PATH: leave unset and the
# corresponding tab shows a clear "not configured" message instead of the
# backend refusing to start. Paths are absolute, ON THE TARGET SERVER,
# reached over the same SFTP/sudo transport as the File Manager tab.
# ---------------------------------------------------------------------------

# The server's plugins/ directory. Required for the Plugins tab.
PLUGINS_DIR=/home/minecraft/server/plugins

# Largest .jar the panel will upload/parse/read into memory (bytes).
PLUGIN_JAR_MAX_SIZE=104857600

# ---------------------------------------------------------------------------
# Backups - lists/downloads/deletes whatever BACKUP_SCRIPT (above) produces.
# Triggering a backup still just runs BACKUP_SCRIPT; this only needs to
# know where to find the result.
# ---------------------------------------------------------------------------
BACKUPS_DIR=/home/minecraft/backups

# ---------------------------------------------------------------------------
# server.properties editor
# ---------------------------------------------------------------------------

# Absolute path to server.properties ON THE TARGET SERVER.
SERVER_PROPERTIES_PATH=/home/minecraft/server/server.properties

# ---------------------------------------------------------------------------
# Server Config (bukkit.yml/spigot.yml) and the Whitelist/Ops tabs
# (whitelist.json/ops.json) - all four normally live in the same directory
# as server.properties, so this is optional: if unset, it's derived from
# SERVER_PROPERTIES_PATH's directory above. Only set it explicitly if these
# files live somewhere else.
# ---------------------------------------------------------------------------
SERVER_ROOT_DIR=/home/minecraft/server

# ---------------------------------------------------------------------------
# Plugin store (Modrinth)
# ---------------------------------------------------------------------------

# Base URL of the Modrinth API. No reason to change this unless you're
# pointing at a mirror/proxy.
MODRINTH_API_URL=https://api.modrinth.com/v2

# ---------------------------------------------------------------------------
# Local data storage - unlike everything else in this file, this is a path
# ON THIS BACKEND'S OWN HOST (no SSH involved), where the scheduler's tasks
# and the audit log are persisted as JSON. In Docker, this needs its own
# volume so it survives container recreation - see docker-compose.yml.
# ---------------------------------------------------------------------------
DATA_DIR=./data
